# ─────────────────────────────────────────────
#  AppTrust Environment Variables
# ─────────────────────────────────────────────

PORT=5000

# Country code for Play Store region (in, us, gb, etc.)
PLAY_STORE_COUNTRY=in

# Language for Play Store data
PLAY_STORE_LANG=en

# Number of reviews to fetch per app (max 150 recommended)
MAX_REVIEWS=100

# Cache duration in seconds (3600 = 1 hour)
CACHE_TTL=3600
